# -----------------------------
# Required: hosted Mistral API
# -----------------------------
MISTRAL_API_KEY=replace_with_your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT=60

# -----------------------------
# Frontend API base (public URL)
# -----------------------------
VITE_API_BASE_URL=https://quiz-backend-vyp4.onrender.com

# -----------------------------
# CORS for frontend domain(s)
# -----------------------------
CORS_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173,http://127.0.0.1:5173

# -----------------------------
# Notification SMTP
# -----------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_sender_email
MAIL_PASSWORD=replace_with_app_password
MAIL_STARTTLS=true
MAIL_AUTH=true
MAIL_FROM_NAME=SIMCO Notifications
